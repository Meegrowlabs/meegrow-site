---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---
<Base title="Home" description="Welcome to our site.">
  <section class="hero">
    <h1>Build. Publish. Grow.</h1>
    <p class="lead">
      A fast marketing site with a built-in blog at <code>/blog</code> — one domain,
      one analytics property, publishable by anyone or any AI editor.
    </p>
    <a class="button" href="/blog">Read the blog →</a>
  </section>

  <section>
    <h2>Latest posts</h2>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
          <span class="meta">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        </li>
      ))}
    </ul>
  </section>
</Base>
