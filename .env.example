# Copy this file to ".env" and fill in your values, OR set these in
# Netlify → Site settings → Environment variables (recommended for production).

# Your live domain (used for canonical URLs, sitemap, RSS). One domain for site + blog.
SITE_URL=https://example.com

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX).
# Get it in GA4 → Admin → Data Streams → your web stream.
PUBLIC_GA4_ID=

# Google Search Console verification token (the value from the "HTML tag" method,
# i.e. the content of <meta name="google-site-verification" content="THIS">).
PUBLIC_GSC_VERIFICATION=
